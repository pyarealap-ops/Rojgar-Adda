        body{background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);color:#333;min-height:100vh;padding:20px}
        .container{max-width:1200px;margin:0 auto}
        header{background:linear-gradient(45deg,#FF6B6B,#4ECDC4);color:white;text-align:center;padding:30px 20px;border-radius:20px;box-shadow:0 10px 30px rgba(0,0,0,.2)}
